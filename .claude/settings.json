{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git log --oneline -5"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(task *)",
      "Bash(make *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(tree *)",
      "WebFetch",
      "WebSearch",
      "Write",
      "Skill"
    ],
    "deny": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(curl *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  }
}
