{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git log --oneline -5"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(echo 'exit: $?')",
      "Bash(tree:*)",
      "Bash(pnpm:*)",
      "Bash(curl:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(source ~/.zshrc)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:nixos.wiki)",
      "WebSearch",
      "Write(**/*.md)",
      "Skill"
    ],
    "deny": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  }
}
