{
  "name": "frontend",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "oxlint --fix .",
    "lint:markup": "markuplint \"src/**/*.tsx\" --fix --problem-only",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-router": "1.170.11",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "1.168.20",
    "@tanstack/router-plugin": "1.168.14",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@markuplint/jsx-parser": "^4.18.3",
    "@playwright/test": "^1.60.0",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/router-cli": "1.167.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.16",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.0",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.9",
    "markuplint": "^4.18.3",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
